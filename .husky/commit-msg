#!/bin/sh
# 커밋 메시지 패턴 검증
# 형식: 태그: 커밋 메시지
# 예시: feat: 로그인 페이지 추가
commit_regex='^((docs|feat|fix|modify|refactor|style|test|chore): .+|(Merge|Revert|Initial|v[0-9]).*)$'

RED='\033[0;31m'
NC='\033[0m' 

if ! grep -qE "$commit_regex" "$1"; then
    echo ""
    echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  ┃                                                                   ┃"
    echo "  ┃  ❌  커밋 메시지 형식이 올바르지 않아요!                          ┃"
    echo "  ┃                                                                   ┃"
    echo "  ┃  [올바른 형식]  태그: 커밋 메시지                                 ┃"
    echo "  ┃  [예시 문구]    feat: 로그인 페이지 추가                          ┃"
    echo "  ┃                                                                   ┃"
    echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  ┃                                                                   ┃"
    echo "  ┃  ✅  사용 가능한 태그                                             ┃"
    echo "  ┃                                                                   ┃"
    echo "  ┃  docs: README나 WIKI 등의 문서 수정                               ┃"
    echo "  ┃  feat: 새로운 기능 추가                                           ┃"
    echo "  ┃  fix: 버그, 오류 수정                                             ┃"
    echo "  ┃  modify: 기능 변경, 오타 등으로 인한 코드 수정                    ┃"
    echo "  ┃  refactor: 기능 변경이 일어나지 않는 유지보수 작업                ┃"
    echo "  ┃            (코드 구조 변경, 불필요한 리소스 삭제, 이름 변경 등)   ┃"
    echo "  ┃  style: UI/UX, 스타일링 등 디자인 관련 작업                       ┃"
    echo "  ┃  test: 테스트 추가 또는 이전 테스트 수정                          ┃"
    echo "  ┃  chore: 빌드, 패키지 관리, 주석 추가 및 수정 등 기타 작업         ┃"
    echo "  ┃                                                                   ┃"
    echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  🙏  ${RED}올바른 형식으로 커밋 메시지를 작성해주세요! ${NC}"
    echo ""
    exit 1
fi

echo "✅ [SUCCESS] 커밋 메시지 형식이 올바릅니다!"